# Aapatt Emergency Superapp - Environment Configuration

# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/aapatt
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Firebase Configuration
FIREBASE_PROJECT_ID=aapatt-emergency
FIREBASE_PRIVATE_KEY_ID=your-private-key-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk@aapatt-emergency.iam.gserviceaccount.com
FIREBASE_CLIENT_ID=your-client-id

# AI Configuration
HUGGING_FACE_API_KEY=hf_your_api_key_here
HUGGING_FACE_API_URL=https://api-inference.huggingface.co

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key
BCRYPT_ROUNDS=12

# API Configuration
API_KEY=your-api-key-for-external-services

# App Configuration
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3000,exp://192.168.1.100:19000

# Logging
LOG_LEVEL=debug

# External Services (Optional)
GOOGLE_MAPS_API_KEY=your_google_maps_key
OSRM_API_URL=http://router.project-osrm.org/route/v1/driving
TWILIO_ACCOUNT_SID=your_twilio_sid
TWILIO_AUTH_TOKEN=your_twilio_token