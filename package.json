{
  "name": "aapatt",
  "version": "1.0.0",
  "description": "Aapatt - Emergency Response Superapp for Developing Countries",
  "private": true,
  "workspaces": [
    "backend",
    "shared",
    "citizen-app",
    "provider-app",
    "admin-dashboard"
  ],
  "scripts": {
    "setup": "node scripts/setup.js",
    "dev:backend": "cd backend && npm run dev",
    "dev:admin": "cd admin-dashboard && npm run dev",
    "dev:citizen": "cd citizen-app && npm start",
    "dev:provider": "cd provider-app && npm start",
    "build:backend": "cd backend && npm run build",
    "build:admin": "cd admin-dashboard && npm run build",
    "build:all": "npm run build:backend && npm run build:admin",
    "install:all": "npm install && npm run install:backend && npm run install:admin && npm run install:citizen && npm run install:provider",
    "install:backend": "cd backend && npm install",
    "install:admin": "cd admin-dashboard && npm install",
    "install:citizen": "cd citizen-app && npm install",
    "install:provider": "cd provider-app && npm install"
  },
  "keywords": [
    "emergency",
    "ambulance",
    "fire-brigade",
    "air-ambulance",
    "react-native",
    "expo",
    "nodejs",
    "postgresql"
  ],
  "author": "Aapatt Team",
  "license": "MIT"
}
