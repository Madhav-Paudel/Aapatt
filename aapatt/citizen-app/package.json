{
  "name": "aapatt-citizen",
  "version": "1.0.0",
  "main": "expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "eject": "expo eject",
    "test": "jest",
    "lint": "eslint .",
    "build:android": "expo build:android",
    "build:ios": "expo build:ios"
  },
  "dependencies": {
    "expo": "~49.0.15",
    "expo-status-bar": "~1.6.0",
    "react": "18.2.0",
    "react-native": "0.72.6",
    "react-native-elements": "^3.4.3",
    "react-native-vector-icons": "^10.0.2",
    "@react-navigation/native": "^6.1.9",
    "@react-navigation/stack": "^6.3.20",
    "@react-navigation/bottom-tabs": "^6.5.11",
    "react-native-screens": "~3.24.0",
    "react-native-safe-area-context": "4.6.3",
    "@expo/vector-icons": "^13.0.0",
    "expo-location": "~15.3.0",
    "expo-camera": "~13.4.4",
    "expo-constants": "~14.4.2",
    "expo-permissions": "~14.2.1",
    "expo-av": "~13.4.1",
    "expo-haptics": "~12.4.0",
    "expo-notifications": "~0.20.1",
    "expo-device": "~5.4.0",
    "socket.io-client": "^4.7.4",
    "axios": "^1.6.2",
    "firebase": "^10.7.1",
    "react-native-maps": "1.7.1",
    "expo-linear-gradient": "~12.3.0",
    "react-native-gesture-handler": "~2.12.0",
    "react-native-reanimated": "~3.3.0",
    "expo-font": "~11.4.0",
    "@react-native-async-storage/async-storage": "1.18.2",
    "react-native-paper": "^5.11.3",
    "expo-app-loading": "~2.1.0",
    "expo-splash-screen": "~0.20.5",
    "expo-updates": "~0.18.17"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@types/react": "~18.2.14",
    "@types/react-native": "^0.72.6",
    "eslint": "^8.19.0",
    "eslint-config-expo": "^6.0.0",
    "jest": "^29.2.1",
    "jest-expo": "~49.0.0",
    "react-test-renderer": "18.2.0"
  },
  "private": true,
  "expo": {
    "name": "Aapatt Citizen",
    "slug": "aapatt-citizen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E53935"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aapatt.citizen",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to location to provide emergency services nearby.",
        "NSCameraUsageDescription": "This app needs access to camera for first-aid assistance.",
        "NSMicrophoneUsageDescription": "This app needs access to microphone for emergency calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E53935"
      },
      "package": "com.aapatt.citizen",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "http://localhost:3000",
      "firebaseConfig": {
        "apiKey": "your-api-key",
        "authDomain": "aapatt-emergency.firebaseapp.com",
        "projectId": "aapatt-emergency"
      }
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Aapatt to use your location to provide emergency services nearby."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Aapatt to access your camera for first-aid assistance."
        }
      ]
    ]
  }
}