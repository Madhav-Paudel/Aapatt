{
  "expo": {
    "name": "Aapatt",
    "slug": "aapatt-citizen",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#E53935"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.aapatt.citizen",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "This app needs access to location to send your location with emergency requests.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "This app needs access to location to send your location with emergency requests.",
        "NSCameraUsageDescription": "This app needs access to camera to analyze injuries for first-aid guidance.",
        "NSMicrophoneUsageDescription": "This app needs access to microphone for emergency calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#E53935"
      },
      "package": "com.aapatt.citizen",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "VIBRATE",
        "WAKE_LOCK",
        "RECEIVE_BOOT_COMPLETED",
        "FOREGROUND_SERVICE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "apiUrl": "http://localhost:3000",
      "firebaseConfig": {
        "apiKey": "your-api-key",
        "authDomain": "aapatt-emergency.firebaseapp.com",
        "projectId": "aapatt-emergency",
        "storageBucket": "aapatt-emergency.appspot.com",
        "messagingSenderId": "123456789",
        "appId": "1:123456789:web:abcdef123456"
      }
    },
    "plugins": [
      "expo-location",
      "expo-camera",
      "expo-notifications",
      [
        "expo-image-picker",
        {
          "photosPermission": "The app accesses your photos to analyze injuries for first-aid guidance."
        }
      ]
    ]
  }
}