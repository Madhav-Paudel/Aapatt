# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/aapatt_db?schema=public"

# Supabase Configuration (for PostgreSQL hosting)
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="your-anon-key"

# Firebase Configuration
FIREBASE_PROJECT_ID="aapatt-emergency"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk-xxxxx@aapatt-emergency.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----\n"

# AI Configuration
HUGGING_FACE_API_KEY="hf_your_api_key_here"
HUGGING_FACE_MODEL_URL="https://api-inference.huggingface.co/models/google/vit-base-patch16-224"

# External Services (Optional)
GOOGLE_MAPS_API_KEY="your_google_maps_key"
OSRM_API_URL="http://router.project-osrm.org/route/v1/driving"

# Security
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
BCRYPT_ROUNDS=12

# App Configuration
NODE_ENV="development"
PORT=3000
CORS_ORIGIN="http://localhost:3000,http://localhost:19006,exp://192.168.1.100:19000"

# Logging
LOG_LEVEL="info"